# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# Django
DJANGO_DEBUG=True

# Postgres
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# OPEN ROUTER
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
#,deepseek/deepseek-r1-0528:free

HOST=http://127.0.0.1:8000
RELOAD=true

# Push Notifications (VAPID Keys)
# Generate these using: python services/api/generate_vapid_keys.py
VAPID_PRIVATE_KEY=your_vapid_private_key_hereb64
VAPID_PUBLIC_KEY=your_vapid_public_key_hereb64
VAPID_CLAIM_EMAIL=mailto:your-email@example.com

# API Service URL (for plombery to send notifications)
API_SERVICE_URL=http://api:8000
