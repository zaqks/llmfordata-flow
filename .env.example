# Example environment variables for tp-vt
# Copy this file to `.env` and set real values as needed.

# Email used for VAPID claims (use mailto: format)
VAPID_CLAIM_EMAIL=mailto:admin@example.com
# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# Django
DJANGO_DEBUG=True

# Postgres
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# OPEN ROUTER
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
#,deepseek/deepseek-r1-0528:free

HOST=http://127.0.0.1:8000
RELOAD=true

# Push Notifications (VAPID Keys)
# Generate these using: python services/api/generate_vapid_keys.py
VAPID_PUBLIC_PATH=/app/vapid_public.txt
VAPID_PRIVATE_PATH=/app/vapid_private.pem
# Email used for VAPID claims (mailto:...)
VAPID_CLAIM_EMAIL=mailto:admin@example.com

# API Service URL (for plombery to send notifications)
API_SERVICE_URL=http://api:8000
