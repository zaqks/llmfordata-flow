# Database (shared between Airflow and Django)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=airflow_django_db
DB_USER=shared_user
DB_PASSWORD=shared_password
DB_HOST=postgres       # or localhost if running locally
DB_PORT=5432

# Airflow
AIRFLOW_HOME=/app/api/airflow
AIRFLOW_UID=1000
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://$DB_USER:$DB_PASSWORD@$DB_HOST/$DB_NAME
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Django
DJANGO_DEBUG=True
